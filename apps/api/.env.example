# Plantilla de variables de entorno del backend.
# Copia este archivo a ".env" y rellena los valores reales:  cp .env.example .env
# El .env real NO se sube al repositorio (contiene secretos).

# Conexión a PostgreSQL. En desarrollo local usa el usuario/clave del docker-compose.yml.
DATABASE_URL="postgresql://skoolar:skoolar_dev@localhost:5433/skoolar?schema=public"

# Conexión a Redis (cache / colas BullMQ).
REDIS_URL="redis://localhost:6379"

# Autenticación JWT. Genera un secreto largo y aleatorio para cada entorno.
# Ejemplo para generarlo:  openssl rand -base64 48
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="15m"
